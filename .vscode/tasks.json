{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "RPG: Build app (g++)",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-g",
        "${workspaceFolder}\\GilbertsWork\\main.cpp",
        "${workspaceFolder}\\GilbertsWork\\character_select.cpp",
        "-o",
        "${workspaceFolder}\\build\\app.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
